# ============================================================
#  Plantilla de configuracion. Copia este archivo como .env
#  y completa con tus valores reales. NUNCA subas .env a git
#  ni lo compartas: contiene credenciales.
# ============================================================

# --- Credenciales del portal DIAN / MUISCA ---
DIAN_TIPO_DOC_EMPRESA=NIT
DIAN_DOC_EMPRESA=900123456
DIAN_TIPO_DOC_USUARIO=CC
DIAN_DOC_USUARIO=10203040
DIAN_PASSWORD=cambia_esto

DIAN_URL=https://catalogo-vpfe.dian.gov.co

# --- OpenAI ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# --- Parametros de conciliacion bancaria ---
CONCILIACION_TOLERANCIA_MONTO=100
CONCILIACION_VENTANA_DIAS=5
